# ──────────────────────────────────────────────
# .env.example — 이 파일을 .env로 복사한 뒤 실제 값으로 채우세요.
#   cp .env.example .env
# .env 파일은 .gitignore에 등록되어 있어 git에 올라가지 않습니다.
# ──────────────────────────────────────────────

# 네이버 개발자센터 (선택 — 없으면 웹 검색으로 대체)
# 발급: https://developers.naver.com → 애플리케이션 등록 → 검색 API
# NAVER_CLIENT_ID: 네이버 검색 API client id
NAVER_CLIENT_ID=YOUR_NAVER_CLIENT_ID_HERE
# NAVER_CLIENT_SECRET: 네이버 검색 API client secret
NAVER_CLIENT_SECRET=YOUR_NAVER_CLIENT_SECRET_HERE

# 이미지 생성 provider (기본: OpenAI)
# IMAGE_PROVIDER: openai 또는 gemini
IMAGE_PROVIDER=openai
# OPENAI_API_KEY: OpenAI 이미지 생성 API 키
OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_IMAGE_MODEL: OpenAI 이미지 모델
OPENAI_IMAGE_MODEL=gpt-image-2

# Gemini 이미지 생성 호환 옵션 (선택)
# IMAGE_PROVIDER=gemini 로 사용할 때만 필요
# GEMINI_API_KEY: Gemini 이미지 생성 API 키
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
# GEMINI_IMAGE_MODEL: Gemini 이미지 모델 override
GEMINI_IMAGE_MODEL=gemini-3-pro-image-preview

# ──────────────────────────────────────────────
# 브랜드 시스템 (/setup-domain이 자동으로 채움 — 수동 편집도 가능)
# ──────────────────────────────────────────────
# BRAND_NAME: 이미지에 표시할 브랜드명
BRAND_NAME=탐정법인 범랑
# BRAND_LOGO_MARK: 이미지에 표시할 짧은 로고 마크
BRAND_LOGO_MARK=BR
# BRAND_PHONE: 이미지 하단에 표시할 전화번호
BRAND_PHONE=1660-2515
# BRAND_BG_COLOR: 이미지 배경색
BRAND_BG_COLOR=#F7F6F2
# BRAND_FG_COLOR: 이미지 본문 텍스트색
BRAND_FG_COLOR=#1A1A1A
# BRAND_ACCENT: 이미지 포인트색
BRAND_ACCENT=#D97A3A
